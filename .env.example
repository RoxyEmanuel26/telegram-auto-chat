# App Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# PostgreSQL Database Connection
DATABASE_URL="postgresql://telehub:telehubpassword@localhost:5432/telehub_db?schema=public"

# Redis Connection (BullMQ Queue)
REDIS_URL="redis://127.0.0.1:6379"

# Cryptographic Keys (Must be secure secrets in production)
JWT_SECRET="telehub-access-jwt-secret-key-12345"
JWT_REFRESH_SECRET="telehub-refresh-jwt-secret-key-12345"

# ENCRYPTION_KEY must be a 64-character hex string (32 bytes) for AES-256-GCM
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
