# App Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# PostgreSQL Database Connection
# Run: pnpm gen:secrets to generate the crypto keys below
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Redis Connection (BullMQ Queue)
REDIS_URL="redis://127.0.0.1:6379"

# Cryptographic Keys — Generate with: pnpm gen:secrets
JWT_SECRET="REPLACE_ME_WITH_GENERATED_SECRET"
JWT_REFRESH_SECRET="REPLACE_ME_WITH_GENERATED_SECRET"

# ENCRYPTION_KEY must be a 64-character hex string (32 bytes) for AES-256-GCM
ENCRYPTION_KEY="REPLACE_ME_WITH_GENERATED_64_CHAR_HEX_STRING"
